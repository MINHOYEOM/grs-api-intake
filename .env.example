# 로컬 dry-run 또는 수동 실행 시 사용하는 예시 환경변수.
# 실제 값은 GitHub Secrets 에만 저장하고, 로컬 .env 파일은 절대 커밋하지 않는다.

# Notion Integration token (secret_ 으로 시작)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "GRM API Intake" Database ID (Notion URL 의 32자 hex)
NOTION_DATABASE_ID=00000000000000000000000000000000

# OpenFDA 무료 API key (선택 — 없으면 no-key 모드, rate limit 낮음)
OPENFDA_API_KEY=

# Brave Search API key (ENABLE_SEARCH=true일 때 필요)
BRAVE_API_KEY=

# 법제처 ogLmPp OC/API 키 (ENABLE_MOLEG_API=true일 때만 사용)
DATA_GO_KR_KEY=

# Feature flags
ENABLE_SEARCH=false
ENABLE_MFDS=false
ENABLE_MOLEG_API=false
ENABLE_SCRAPE=false
